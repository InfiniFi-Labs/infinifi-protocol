[submodule "lib/forge-std"]
	path = lib/forge-std
	url = https://github.com/foundry-rs/forge-std
[submodule "lib/openzeppelin-contracts"]
	path = lib/openzeppelin-contracts
	url = https://github.com/OpenZeppelin/openzeppelin-contracts
[submodule "lib/solmate"]
	path = lib/solmate
	url = https://github.com/transmissions11/solmate.git
[submodule "lib/cowprotocol"]
	path = lib/cowprotocol
	url = https://github.com/cowprotocol/contracts.git
[submodule "lib/contracts"]
	path = lib/contracts
	url = https://github.com/cowprotocol/contracts
